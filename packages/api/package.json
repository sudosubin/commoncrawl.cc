{
  "name": "@commoncrawl.cc/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev src/index.ts",
    "build": "wrangler deploy --dry-run --outdir dist",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run test",
    "openapi:export": "tsx ./scripts/export-openapi.ts && pnpm exec oxfmt openapi.json"
  },
  "dependencies": {
    "@hono/standard-validator": "^0.2.2",
    "@valibot/to-json-schema": "^1.5.0",
    "hono": "^4.12.3",
    "hono-openapi": "^1.2.0",
    "valibot": "^1.2.0"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.11.0",
    "@typescript/native-preview": "7.0.0-dev.20260227.1",
    "tsx": "^4.20.6",
    "vitest": "4.1.0-beta.5",
    "wrangler": "^4.57.1"
  }
}
