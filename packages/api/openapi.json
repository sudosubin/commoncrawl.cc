          "503": {
            "description": "Service Unavailable",
            "content": {
              "text/plain": {
                "schema": { "type": "string" },
                "example": "Service Unavailable"
              },
              "text/html": {
                "schema": { "type": "string" },
                "example": "<html><body><h1>503 Service Unavailable</h1></body></html>"
              }
            }
          }
        },
        "parameters": [
          {
            "schema": { "type": "string" },
            "in": "path",
            "name": "coll",
            "required": true
          },
          {
            "schema": { "type": "string" },
            "in": "path",
            "name": "url",
            "required": true
