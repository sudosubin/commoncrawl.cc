    "/api/v1/index/{coll}/{timestamp}/{url}": {
      "get": {
        "operationId": "getApiV1IndexByCollByTimestampByUrl",
        "summary": "Memento API",
        "description": "pywb supports the Memento Protocol as specified in RFC 7089 and provides API endpoints for Memento TimeMaps and TimeGates per collection.",
        "responses": {
          "200": {
            "description": "The 'canonical' URI-M is included in the ``content-location`` header and should be used to reference the memento in the future.",
            "content": {
              "text/html": {
                "schema": { "type": "string" },
                "example": "<!doctype html><html lang=\"en\"><head>\n<!-- WB Insert -->\n<script>\nwbinfo = {};\nwbinfo.top_url = \"https://index.commoncrawl.org/CC-MAIN-2026-08/20260206181759/https://www.example.com/\";\nwbinfo.url = \"https://www.example.com/\";\nwbinfo.timestamp = \"20260206181759\";\n</script>\n</head><body></body></html>"
              },
              "application/octet-stream": {
                "schema": { "type": "string" },
                "example": "\\u0089PNG\\r\\n\\u001a\\n\\u0000\\u0000\\u0000\\rIHDR..."
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "text/plain": {
                "schema": { "type": "string" },
                "example": "Not Found"
              }
            }
          },
          "429": {
            "description": "Too Many Requests",
            "content": {
              "text/plain": {
                "schema": { "type": "string" },
                "example": "Too Many Requests"
              },
              "text/html": {
                "schema": { "type": "string" },
                "example": "<html><body><h1>429 Too Many Requests</h1></body></html>"
              }
            }
          },
          "503": {
            "description": "Service Unavailable",
            "content": {
              "text/plain": {
                "schema": { "type": "string" },
                "example": "Service Unavailable"
              },
              "text/html": {
                "schema": { "type": "string" },
                "example": "<html><body><h1>503 Service Unavailable</h1></body></html>"
              }
            }
          }
        },
        "parameters": [
          {
            "schema": { "type": "string" },
            "in": "path",
            "name": "coll",
            "required": true
          },
          {
            "schema": { "type": "string" },
            "in": "path",
            "name": "timestamp",
            "required": true
          },
          {
            "schema": { "type": "string" },
            "in": "path",
            "name": "url",
            "required": true
          }
        ]
      }
    },
    "/api/v1/index/{coll}/{url}": {
      "get": {
        "operationId": "getApiV1IndexByCollByUrl",
        "summary": "TimeGate API",
        "description": "The TimeGate API for any pywb collection is ``/<coll>/<url>``, eg. ``/my-coll/http://example.com/``.",
        "responses": {
          "200": {
            "description": "To avoid an extra redirect, the TimeGate returns the requested memento directly (200-style negotiation) without redirecting to its canonical, timestamped url.",
